---
const stats = [
  { number: '250+', label: 'meetings/day\ndocumented' },
  { number: '6', label: 'documentation\ncategories' },
  { number: '5', label: 'platforms\ncovered' },
  { number: '4', label: 'internal tools\ndocumented' },
];
---

<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
  {stats.map(stat => (
    <div class="stat-badge">
      <span class="number">{stat.number}</span>
      <span class="label" style="white-space: pre-line;">{stat.label}</span>
    </div>
  ))}
</div>
