---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `${base}/work`, label: 'Work' },
  { href: `${base}/process`, label: 'Process' },
  { href: `${base}/about`, label: 'About' },
];
---

<header class="sticky top-0 z-50 border-b" style="background: rgba(0,0,0,0.95); backdrop-filter: blur(8px); border-color: var(--color-border);">
  <div class="max-w-content mx-auto px-6 h-16 flex items-center justify-between">
    <a href={base || '/'} class="flex items-center gap-2 group">
      <span
        class="font-bold text-sm tracking-tight transition-colors"
        style="font-family: 'JetBrains Mono', Menlo, monospace; color: var(--color-accent);"
      >
        &gt; HR
      </span>
    </a>

    <nav class="flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="px-3 py-1.5 text-sm font-medium transition-colors"
          style={currentPath.startsWith(link.href)
            ? 'color: var(--color-accent);'
            : 'color: var(--color-text-secondary);'}
        >
          {link.label}
        </a>
      ))}
      <a
        href={`${base}/assets/Heath%20Reinhard%20Resume.pdf`}
        target="_blank"
        rel="noopener"
        class="btn-primary ml-3 text-sm"
      >
        Resume ↗
      </a>
    </nav>
  </div>
</header>
