---
const year = new Date().getFullYear();
---

<footer class="border-t mt-24" style="border-color: var(--color-border);">
  <div class="max-w-content mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs" style="color: var(--color-text-secondary); font-family: 'JetBrains Mono', Menlo, monospace;">
    <span style="color: var(--color-text-secondary);">© {year} Heath Reinhard</span>
    <div class="flex items-center gap-5">
      <a
        href="https://www.linkedin.com/in/heath-reinhard/"
        target="_blank"
        rel="noopener"
        class="transition-colors font-medium"
        style="color: var(--color-text-secondary);"
        onmouseover="this.style.color='var(--color-accent)'"
        onmouseout="this.style.color='var(--color-text-secondary)'"
      >
        LinkedIn
      </a>
      <a
        href="mailto:heath.reinhard@gmail.com"
        class="transition-colors font-medium"
        style="color: var(--color-text-secondary);"
        onmouseover="this.style.color='var(--color-accent)'"
        onmouseout="this.style.color='var(--color-text-secondary)'"
      >
        Get in Touch
      </a>
      <a
        href="https://github.com/agentheath/portfolio"
        target="_blank"
        rel="noopener"
        class="transition-colors font-medium"
        style="color: var(--color-text-secondary);"
        onmouseover="this.style.color='var(--color-accent)'"
        onmouseout="this.style.color='var(--color-text-secondary)'"
      >
        Source
      </a>
    </div>
  </div>
</footer>
