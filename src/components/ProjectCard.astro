---
interface Props {
  title: string;
  description: string;
  tags: string[];
  metric?: string;
  metricLabel?: string;
  href: string;
  featured?: boolean;
}

const { title, description, tags, metric, metricLabel, href, featured = false } = Astro.props;
---

<a href={href} class="project-card block no-underline group">
  <div class="flex items-start justify-between gap-4">
    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="doc-tag">{tag}</span>
      ))}
    </div>
    {metric && (
      <div class="flex-shrink-0 text-right">
        <div class="font-bold text-xl leading-none" style="color: var(--color-accent); font-family: 'JetBrains Mono', Menlo, monospace;">
          {metric}
        </div>
        {metricLabel && (
          <div class="text-xs mt-0.5" style="color: var(--color-text-secondary);">{metricLabel}</div>
        )}
      </div>
    )}
  </div>

  <h3
    class="font-bold text-base mt-3 transition-colors"
    style="font-family: 'JetBrains Mono', Menlo, monospace; color: var(--color-text);"
  >
    <span style="color: var(--color-accent);">// </span>{title}
  </h3>

  <p class="text-sm mt-1 leading-relaxed" style="color: var(--color-text-secondary);">
    {description}
  </p>

  <div
    class="mt-4 text-xs font-medium flex items-center gap-1 transition-colors"
    style="color: var(--color-accent); font-family: 'JetBrains Mono', Menlo, monospace;"
  >
    view project →
  </div>
</a>
