---
interface Props {
  title: string;
  description: string;
  tags: string[];
  metric?: string;
  metricLabel?: string;
  href: string;
  featured?: boolean;
}

const { title, description, tags, metric, metricLabel, href, featured = false } = Astro.props;
---

<a href={href} class="project-card block no-underline group">
  <div class="flex items-start justify-between gap-4">
    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="doc-tag">{tag}</span>
      ))}
    </div>
    {metric && (
      <div class="flex-shrink-0 text-right">
        <div class="font-extrabold text-xl leading-none" style="color: var(--color-accent); font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
          {metric}
        </div>
        {metricLabel && (
          <div class="text-xs mt-0.5" style="color: #115E59;">{metricLabel}</div>
        )}
      </div>
    )}
  </div>

  <h3
    class="font-bold text-lg mt-3 transition-colors group-hover:text-teal-700"
    style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: var(--color-text);"
  >
    {title}
  </h3>

  <p class="text-sm mt-1" style="color: var(--color-text-secondary);">
    {description}
  </p>

  <div
    class="mt-4 text-sm font-medium flex items-center gap-1 transition-colors"
    style="color: var(--color-accent);"
  >
    View project
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" class="transition-transform group-hover:translate-x-0.5">
      <path d="M2.5 7H11.5M7 2.5L11.5 7L7 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>
