---
import Base from '@layouts/Base.astro';

const base = import.meta.env.BASE_URL;
---

<Base
  title="About — Heath Reinhard"
  description="Heath Reinhard is a technical writer and editor specializing in developer documentation, internal tooling, and data-driven content strategy."
>
  <div class="max-w-content mx-auto px-6 pt-16 pb-24">
    <div class="grid lg:grid-cols-3 gap-12">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <p class="section-label mb-2">About Me</p>
        <h1
          class="text-4xl font-extrabold mb-6"
          style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;"
        >
          Heath Reinhard
        </h1>
        <p class="text-lg mb-2 font-medium" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
          Technical Writer · Editor · AI-Native
        </p>

        <div class="space-y-5 mt-6 max-w-2xl" style="color: var(--color-text-secondary);">
          <p>
            I'm a versatile writer and editor who specializes in translating complex technical, scientific,
            and historical subject matter into clear, usable content. My work spans developer documentation,
            governance frameworks, user guides, and editorial articles — written for audiences ranging from
            kindergarteners to senior engineers.
          </p>
          <p>
            I have a particular passion for internal tooling documentation: the kind that nobody thinks
            about until it doesn't exist, and then costs ten times as much in support load, onboarding
            friction, and tribal knowledge loss. I've written docs that supported tools processing 250+
            meetings a day and governance frameworks that brought structure to platforms serving thousands
            of employees.
          </p>
          <p>
            I embrace AI tools in my documentation workflow — not as a shortcut, but as leverage.
            I use them for gap analysis, outline generation, consistency checking, and SME interview prep.
            I believe the technical writers who thrive in the next decade will be the ones who learn to
            work with AI rather than around it.
          </p>
          <p>
            Outside of tech writing, I have a passion for brevity and an obsession with eliminating
            superfluous commas wherever I find them.
          </p>
        </div>

        <!-- What I'm looking for -->
        <div class="mt-14">
          <h2
            class="text-2xl font-bold mb-5"
            style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;"
          >
            What I'm Looking For
          </h2>
          <p class="mb-5 max-w-2xl" style="color: var(--color-text-secondary);">
            You might be my kind of company if you:
          </p>
          <ul class="space-y-3 max-w-2xl">
            {[
              'Hire talented people and empower them to solve problems both collaboratively and autonomously',
              'Believe that documentation is a powerful tool for enabling engineering productivity and velocity at scale',
              'Are remote-friendly and properly support distributed employees financially and technologically',
              'Drive decision-making with data and metrics',
              'Have a strong culture of learning and growth',
              'Lean into using generative AI tools to augment documentation workflows',
              'Focus on creating real-world impact while also having fun and a sense of humor',
            ].map(item => (
              <li class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <circle cx="9" cy="9" r="8" stroke="#0F766E" stroke-width="1.5"/>
                  <path d="M6 9L8 11L12 7" stroke="#0F766E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-sm" style="color: var(--color-text-secondary);">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- About This Site -->
        <div class="mt-14 p-6 rounded-xl border" style="border-color: var(--color-border);">
          <h3
            class="font-bold text-base mb-3"
            style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;"
          >
            About This Site
          </h3>
          <p class="text-sm" style="color: var(--color-text-secondary);">
            This site was rebuilt from the ground up with <strong>Astro</strong> and <strong>Tailwind CSS</strong>,
            deployed via GitHub Actions to GitHub Pages. All content is authored in Markdown — the same
            docs-as-code workflow I use professionally. The rebuild was done in collaboration with Claude
            as a demonstration of AI-native development and documentation workflow.
            <a href="https://github.com/agentheath/portfolio" target="_blank" rel="noopener" style="color: var(--color-accent);" class="font-medium">
              View the source on GitHub.
            </a>
          </p>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <!-- Links card -->
          <div class="p-5 rounded-xl border" style="border-color: var(--color-border);">
            <h3
              class="font-semibold text-sm mb-4"
              style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;"
            >
              Get in Touch
            </h3>
            <div class="space-y-3">
              <a
                href="mailto:heath.reinhard@gmail.com"
                class="flex items-center gap-3 text-sm font-medium transition-colors hover:text-teal-700"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M2 4C2 3.45 2.45 3 3 3H13C13.55 3 14 3.45 14 4V12C14 12.55 13.55 13 13 13H3C2.45 13 2 12.55 2 12V4Z" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M2 4L8 8.5L14 4" stroke="currentColor" stroke-width="1.3"/>
                </svg>
                heath.reinhard@gmail.com
              </a>
              <a
                href="https://www.linkedin.com/in/heath-reinhard/"
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 text-sm font-medium transition-colors hover:text-teal-700"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M13.5 2H2.5C2.22 2 2 2.22 2 2.5V13.5C2 13.78 2.22 14 2.5 14H13.5C13.78 14 14 13.78 14 13.5V2.5C14 2.22 13.78 2 13.5 2ZM5.5 12H4V6.5H5.5V12ZM4.75 5.75C4.22 5.75 3.8 5.33 3.8 4.8C3.8 4.27 4.22 3.85 4.75 3.85C5.28 3.85 5.7 4.27 5.7 4.8C5.7 5.33 5.28 5.75 4.75 5.75ZM12 12H10.5V9.4C10.5 8.42 10.47 7.17 9.13 7.17C7.77 7.17 7.56 8.23 7.56 9.33V12H6.06V6.5H7.5V7.56H7.52C7.72 7.19 8.21 6.8 8.95 6.8C10.41 6.8 11 7.63 11 8.96V12H12Z"/>
                </svg>
                LinkedIn
              </a>
              <a
                href={`${base}/assets/Heath%20Reinhard%20Resume.pdf`}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 text-sm font-medium transition-colors hover:text-teal-700"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M4 1H10L14 5V15H4V1Z" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M10 1V5H14" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M6 8H10M6 11H10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                Download Resume
              </a>
            </div>
          </div>

          <!-- Skills -->
          <div class="p-5 rounded-xl border" style="border-color: var(--color-border);">
            <h3
              class="font-semibold text-sm mb-4"
              style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;"
            >
              Expertise
            </h3>
            <div class="flex flex-wrap gap-2">
              {[
                'Technical Documentation',
                'User Guides',
                'Governance Frameworks',
                'Docs-as-Code',
                'AI-Assisted Writing',
                'Information Architecture',
                'Editorial Writing',
                'SME Collaboration',
                'Markdown / MDX',
                'Git / GitHub',
                'Jekyll / Astro',
                'Analytics',
              ].map(skill => (
                <span
                  class="text-xs px-2.5 py-1 rounded-full border font-medium"
                  style="border-color: var(--color-border); color: var(--color-text-secondary);"
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>
