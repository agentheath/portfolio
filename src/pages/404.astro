---
import Base from '@layouts/Base.astro';

const base = import.meta.env.BASE_URL;
---

<Base title="404 — Heath Reinhard">
  <div class="max-w-content mx-auto px-6 py-32 text-center">
    <p class="section-label mb-6">404</p>
    <h1
      class="text-3xl font-extrabold mb-6 leading-relaxed"
      style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;"
    >
      The web site you seek<br />
      cannot be located but<br />
      endless others exist
    </h1>
    <p class="text-sm mb-8" style="color: var(--color-text-secondary);">— a haiku</p>
    <a href={base || '/'} class="btn-primary">
      Go home
    </a>
  </div>
</Base>
