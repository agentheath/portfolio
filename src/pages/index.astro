---
import Base from '@layouts/Base.astro';
import StatBar from '@components/StatBar.astro';
import ProjectCard from '@components/ProjectCard.astro';

const base = import.meta.env.BASE_URL;

const featuredProjects = [
  {
    title: 'Getting Started with the Claude API',
    description: 'A developer tutorial walking through Claude API integration from installation to a working Python document summarizer.',
    tags: ['Developer Education', 'Tutorial'],
    metric: '0 → working app',
    metricLabel: 'in one tutorial',
    href: `${base}/work/claude-api-tutorial`,
  },
  {
    title: 'Meeting Recording Tool',
    description: 'User guide for an enterprise VC recording and streaming platform used to document 250+ meetings per day.',
    tags: ['User Guide', 'Enterprise'],
    metric: '250+',
    metricLabel: 'meetings/day',
    href: `${base}/work/meeting-recording-tool`,
  },
  {
    title: 'Mobile App Governance Framework',
    description: 'End-to-end governance framework and compliance checklist co-developed with PMs, designers, engineers, and leadership.',
    tags: ['Governance', 'Framework'],
    metric: '6',
    metricLabel: 'review categories',
    href: `${base}/work/mobile-app`,
  },
];
---

<Base>
  <!-- Hero -->
  <section class="max-w-content mx-auto px-6 pt-20 pb-16 border-b" style="border-color: var(--color-border);">
    <p class="section-label mb-4">&gt; TECHNICAL WRITER · DEVELOPER EDUCATION</p>
    <h1
      class="text-5xl sm:text-6xl font-bold leading-none tracking-tight mb-6 cursor-blink"
      style="font-family: 'JetBrains Mono', Menlo, monospace; color: var(--color-text);"
    >
      Heath Reinhard
    </h1>
    <p
      class="text-base sm:text-lg leading-relaxed mb-8 max-w-xl"
      style="color: var(--color-text-secondary);"
    >
      I turn complex APIs into confident builders — and keep teams out of the weeds.
      Documentation that ships with the product.
    </p>
    <div class="flex flex-wrap items-center gap-3">
      <a href={`${base}/work`} class="btn-primary">
        view_my_work() →
      </a>
      <a href="mailto:heath.reinhard@gmail.com" class="btn-secondary">
        get_in_touch()
      </a>
    </div>
  </section>

  <!-- Impact Stats -->
  <section class="max-w-content mx-auto px-6 py-12 border-b" style="border-color: var(--color-border);">
    <p class="section-label mb-6">&gt; IMPACT_AT_A_GLANCE</p>
    <StatBar />
  </section>

  <!-- Featured Work -->
  <section class="max-w-content mx-auto px-6 py-16 border-b" style="border-color: var(--color-border);">
    <div class="flex items-baseline justify-between mb-8">
      <div>
        <p class="section-label mb-1">&gt; SELECTED_WORK</p>
        <h2
          class="text-xl font-bold"
          style="font-family: 'JetBrains Mono', Menlo, monospace;"
        >
          Featured Projects
        </h2>
      </div>
      <a href={`${base}/work`} class="text-sm font-medium transition-colors" style="color: var(--color-accent); font-family: 'JetBrains Mono', Menlo, monospace;">
        all_projects →
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px" style="background: var(--color-border);">
      {featuredProjects.map(project => (
        <div style="background: #000;">
          <ProjectCard {...project} featured />
        </div>
      ))}
    </div>
  </section>

  <!-- Value Prop / AI + Data -->
  <section class="max-w-content mx-auto px-6 py-16 border-b" style="border-color: var(--color-border);">
    <p class="section-label mb-8">&gt; METHODOLOGY</p>
    <div class="grid sm:grid-cols-2 gap-12 max-w-3xl">
      <div>
        <h3 class="font-bold text-base mb-3" style="font-family: 'JetBrains Mono', Menlo, monospace; color: var(--color-accent);">
          // AI-Native Workflow
        </h3>
        <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-secondary);">
          I use AI tools throughout the documentation lifecycle — from gap analysis and outline generation to consistency reviews and terminology checks. Faster delivery without sacrificing accuracy or voice.
        </p>
        <a href={`${base}/process`} class="text-sm font-medium inline-block transition-colors" style="color: var(--color-accent); font-family: 'JetBrains Mono', Menlo, monospace;">
          see_my_process →
        </a>
      </div>

      <div>
        <h3 class="font-bold text-base mb-3" style="font-family: 'JetBrains Mono', Menlo, monospace; color: var(--color-accent);">
          // Data-Driven by Default
        </h3>
        <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-secondary);">
          Good documentation is measurable. I identify content gaps through analytics and support ticket analysis, measure effectiveness via adoption and deflection metrics, and iterate the same way engineers iterate on code.
        </p>
        <a href={`${base}/process#data-driven`} class="text-sm font-medium inline-block transition-colors" style="color: var(--color-accent); font-family: 'JetBrains Mono', Menlo, monospace;">
          my_methodology →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-content mx-auto px-6 py-16">
    <div
      class="p-10 border"
      style="background: var(--color-accent-light); border-color: rgba(0,255,136,0.2);"
    >
      <p class="section-label mb-3">&gt; OPEN_TO_WORK</p>
      <h2
        class="text-xl font-bold mb-3"
        style="font-family: 'JetBrains Mono', Menlo, monospace; color: var(--color-accent);"
      >
        Looking for a developer education lead?
      </h2>
      <p class="mb-6 text-sm" style="color: var(--color-text-secondary);">
        Open to full-time and contract roles in developer education, content strategy, and technical writing.
        Let's talk about what your team needs.
      </p>
      <a href="mailto:heath.reinhard@gmail.com" class="btn-primary">
        get_in_touch() →
      </a>
    </div>
  </section>
</Base>
